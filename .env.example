# Environment Variables - Copy this to .env and fill in the values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart_waste_db?retryWrites=true&w=majority

# JWT secret key (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this

# JWT expiry
JWT_EXPIRE=24h

# Server port (Render/Railway set this automatically)
PORT=5000

# Node environment
NODE_ENV=production

# CORS allowed origin (set to your Vercel URL in production)
# CORS_ORIGIN=https://smart-waste-collection.vercel.app
